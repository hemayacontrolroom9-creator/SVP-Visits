# ============================================================
# Hemaya VMS — Environment Configuration
# Copy to .env and fill in all values before running
# NEVER commit .env to version control
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Production domain (used by docker-compose.production.yml)
DOMAIN=vms.hemaya.ae

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
# REQUIRED: Change this before running
DB_PASSWORD=CHANGE_ME_strong_password_min_20_chars
DB_NAME=supervisor_visits
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=2

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REQUIRED: Change this before running
REDIS_PASSWORD=CHANGE_ME_redis_password_min_16_chars
REDIS_DB=0
REDIS_TTL=3600

# ── JWT ──────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_32_random_chars_here
JWT_EXPIRATION=15m
# REQUIRED: Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_different_from_jwt_secret
JWT_REFRESH_EXPIRATION=7d

# ── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# REQUIRED: Generate with: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_32_char_hex_encryption_key
SESSION_SECRET=CHANGE_ME_session_secret_long_random_string

# ── Google Maps ──────────────────────────────────────────────
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GEOCODING_KEY=

# ── File Storage (MinIO for dev, S3 for prod) ────────────────
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=hemaya-vms

# AWS S3 (for production)
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=hemaya-vms-uploads

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@hemaya.ae
EMAIL_FROM_NAME=Hemaya Security Services

# ── Firebase Push Notifications ──────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=5

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_PORT=9464
LOG_LEVEL=info
# Set to Loki container URL in production; leave empty to disable
LOKI_HOST=

# ── Monitoring Dashboard ─────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
VITE_GOOGLE_MAPS_KEY=
VITE_SENTRY_DSN=
